# =============================================================================
# VeloDB Demo — environment overrides (optional)
# Copy to `.env` and tweak.
# =============================================================================

# ----- Image tags (publish target: Docker Hub, namespace `velodb`) -----------
IMAGE_TAG=4.1.0
DORIS_VERSION=4.1.0
BACKEND_IMAGE=velodb/velodb-demo-backend
FRONTEND_IMAGE=velodb/velodb-demo-frontend
GRAFANA_IMAGE=velodb/velodb-demo-grafana
TELEMETRY_GEN_IMAGE=velodb/velodb-demo-telemetry-generator
RAG_IMAGE=velodb/velodb-demo-rag-api

# ----- Host ports ------------------------------------------------------------
FRONTEND_PORT=5173
BACKEND_PORT=8081
DORIS_FE_HTTP_PORT=8030
DORIS_FE_QUERY_PORT=9030
DORIS_BE_HTTP_PORT=8040
POSTGRES_PORT=5432
REDPANDA_PORT=9092
GRAFANA_PORT=33000
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
RAG_PORT=8000

# ----- Postgres credentials --------------------------------------------------
POSTGRES_DB=demo_db
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=demo_password_123
DATA_RETENTION_DAYS=3

# ----- Demo data generators --------------------------------------------------
GENERATOR_ENABLED=true
GENERATOR_PARTNER_ID=44
GENERATOR_ORDERS_RATE=10
GENERATOR_CLICKSTREAM_RATE=10

# ----- Grafana ---------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin


# ----- RAG (optional, only used with --profile rag) --------------------------
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=
RAG_CHAT_MODEL=amazon/nova-micro-v1
RAG_VISION_MODEL=amazon/nova-lite-v1
ASSET_STORAGE_BACKEND=local

# OTEL collector writes datetimes as literal strings in this timezone, so
# the Grafana doris-app's "Last N hours" filter (which sends browser-local
# literals) matches the stored data. Set this to your *browser's* timezone.
# Examples: America/Los_Angeles, America/New_York, Europe/London,
#           Europe/Berlin, Asia/Shanghai, Asia/Tokyo, UTC
# Full setup steps: see dist/docs/TIMEZONE.md
OTEL_TIMEZONE=America/Los_Angeles
